{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Plugin Configuration",
    "description": "Schema for marketplace.json plugin configuration",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "description": "Plugin name"
        },
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "SemVer version"
        },
        "description": {
            "type": "string",
            "description": "Plugin description"
        },
        "author": {
            "type": "string",
            "description": "Author name or organization"
        },
        "license": {
            "type": "string",
            "description": "SPDX license identifier"
        },
        "agents": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of available agents"
        },
        "skills": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of available skills"
        },
        "commands": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of available commands"
        },
        "hooks": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of configured hooks"
        }
    },
    "required": [
        "name",
        "version",
        "description"
    ]
}