{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Hooks Configuration",
    "description": "Schema for hooks.json configuration file",
    "type": "object",
    "properties": {
        "hooks": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "PreToolUse",
                            "PostToolUse",
                            "PreCompact",
                            "SessionStart",
                            "SessionEnd",
                            "Stop"
                        ],
                        "description": "Hook lifecycle event type"
                    },
                    "matcher": {
                        "type": "string",
                        "description": "Tool or event matcher pattern (* for all)"
                    },
                    "description": {
                        "type": "string",
                        "description": "Human-readable description of what the hook does"
                    },
                    "command": {
                        "type": "string",
                        "description": "Command to execute (node script or shell command)"
                    }
                },
                "required": [
                    "type",
                    "matcher",
                    "command"
                ]
            }
        }
    },
    "required": [
        "hooks"
    ]
}